{
  "kind": "collectionType",
  "collectionName": "home_texts",
  "info": {
    "singularName": "home-text",
    "pluralName": "home-texts",
    "displayName": "Home Text Section",
    "description": "Text content sections for the homepage"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "subtitle": {
      "type": "string",
      "required": false,
      "maxLength": 300
    },
    "content": {
      "type": "richtext",
      "required": false
    },
    "section": {
      "type": "enumeration",
      "enum": ["hero", "about", "features", "testimonial", "cta"],
      "required": true,
      "default": "hero"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "order": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "required": false,
      "default": true
    }
  }
}
