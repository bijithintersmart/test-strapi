{
  "kind": "collectionType",
  "collectionName": "about_histories",
  "info": {
    "singularName": "about-history-timeline",
    "pluralName": "about-history-timelines",
    "displayName": "About History Timeline",
    "description": "Company history timeline for the about page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "required": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "milestone": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "category": {
      "type": "enumeration",
      "enum": ["founding", "growth", "product", "award", "expansion", "other"],
      "required": false
    },
    "order": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "required": false,
      "default": true
    }
  }
}
