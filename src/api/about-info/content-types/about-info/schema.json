{
  "kind": "collectionType",
  "collectionName": "about_infos",
  "info": {
    "singularName": "about-info",
    "pluralName": "about-infos",
    "displayName": "About Info",
    "description": "Main about page information content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "subtitle": {
      "type": "string",
      "required": false,
      "maxLength": 300
    },
    "mainContent": {
      "type": "richtext",
      "required": true
    },
    "mission": {
      "type": "richtext",
      "required": false
    },
    "vision": {
      "type": "richtext",
      "required": false
    },
    "values": {
      "type": "json",
      "required": false,
      "description": "Array of company values"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "videoUrl": {
      "type": "string",
      "required": false
    },
    "order": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "required": false,
      "default": true
    }
  }
}
